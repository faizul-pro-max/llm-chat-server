# vLLM Bearer token — same secret used by the app server
VLLM_API_KEY=change_me_vllm_key

# Observer agent x-api-key header value
AGENT_SECRET=change_me_agent_secret

# HuggingFace token (required for gated models like Llama)
HF_TOKEN=hf_your_token_here

# Model cache location — point to a persistent volume on Vast.ai
HF_HOME=/root/.cache/huggingface

# Directory where tmux pipe logs are written
LOG_DIR=./logs

# ngrok auth token — get yours at https://dashboard.ngrok.com/get-started/your-authtoken
# Required only if you run: bash scripts/tunnel.sh
NGROK_AUTHTOKEN=your_ngrok_authtoken_here
