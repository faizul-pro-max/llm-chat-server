## tmux Session Management

### Session names
- `vllm` — the vLLM server process
- `agent` — the observer-agent FastAPI process

### Library: libtmux

```python
# src/utils/tmux.py
import libtmux

def create_session(name: str, command: str, log_file: str = None):
    """Create new tmux session and run command. Pipes output to log_file if given."""
    server = libtmux.Server()
    if server.has_session(name):
        raise RuntimeError(f"Session '{name}' already exists. Run `make stop` first.")
    session = server.new_session(session_name=name, detach=True, kill_session=False)
    pane = session.attached_pane
    if log_file:
        pane.send_keys(f"exec > >(tee {log_file}) 2>&1")
    pane.send_keys(command)

def is_running(name: str) -> bool:
    server = libtmux.Server()
    return server.has_session(name)

def kill_session(name: str):
    server = libtmux.Server()
    if server.has_session(name):
        server.kill_session(name)

def capture_pane(name: str, lines: int = 50) -> str:
