## CLI Commands (src/cli.py)

```python
import click

@click.group()
def cli():
    """GPU Server Orchestrator — manage vLLM + metrics agent lifecycle."""

@cli.command()
@click.option('--skip-network', is_flag=True, help='Skip network speed test')
@click.option('--scenario', default='baseline', help='Scenario to validate against')
def doctor(skip_network, scenario):
    """Run pre-flight checks. NO GPU cost — run this first."""

@cli.command()
@click.option('--scenario', required=True)
@click.option('--no-warmup', is_flag=True)
@click.option('--no-download', is_flag=True)
def start(scenario, no_warmup, no_download):
    """Full lifecycle: doctor → download → start vLLM + agent → warmup → ready."""

@cli.command()
@click.option('--service', type=click.Choice(['vllm', 'agent', 'all']), default='all')
def stop(service):
    """Stop tmux sessions for vLLM / agent."""

@cli.command()
def status():
    """Show service status — tmux sessions + health endpoints."""

@cli.command()
@click.option('--service', type=click.Choice(['vllm', 'agent']))
@click.option('--tail', default=50)
def logs(service, tail):
    """Tail log files from tmux sessions."""

@cli.group()
def scenarios():
    """Scenario management commands."""

@scenarios.command(name='list')
def list_scenarios():
    """List all available scenarios."""

@scenarios.command()
@click.argument('name')
def show(name):
    """Show full config of a scenario."""

if __name__ == '__main__':
    cli()
```

